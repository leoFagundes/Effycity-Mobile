      "package": "com.leofagundes.effycity"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": "46c61ed2-d1cb-4bb5-8912-27f5a8685ab7"
